{
  "name": "ufc-fantasy-lines-grabber",
  "version": "2.1.0",
  "description": "Auto-fetches UFC fantasy lines from Pick6 & Underdog, detects upcoming cards, and updates the analyzer automatically.",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "snapshot:analyzer": "node snapshot-analyzer.js",
    "archive:clean:betr": "node clean-betr-lingering.js",
    "archive:import:settle": "node import-betr-settle-lines.js --file betr-settle-input.json",
    "archive:import:settle:dry": "node import-betr-settle-lines.js --file betr-settle-input.json --dry-run",
    "archive:backfill": "node backfill-archive-results.js",
    "report:london": "node grade-london-best-picks.js",
    "prebuild": "npm run clean",
    "checkpoint:save": "powershell -ExecutionPolicy Bypass -File .\\resume.ps1 -Mode save",
    "checkpoint:save:snapshot": "powershell -ExecutionPolicy Bypass -File .\\resume.ps1 -Mode save -CreateSnapshot",
    "checkpoint:resume": "powershell -ExecutionPolicy Bypass -File .\\resume.ps1 -Mode resume"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "puppeteer": "^24.40.0"
  }
}
